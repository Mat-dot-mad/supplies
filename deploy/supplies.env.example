# Copied to /etc/supplies.env on the Pi (root-owned, mode 0640).
# No DASHBOARD_PASSWORD / SECRET_KEY because we chose "no auth — Tailscale
# is the perimeter". If you change your mind later, add them here and copy
# the `before_request` auth pattern from portfolio/app.py.

PORT=5002
DATABASE_PATH=/var/lib/supplies/supplies.db
